# Accelance AI Platform — Environment Variables
# Copy this file to .env and replace dummy values with your real cloud credentials.
# .env is gitignored — never commit it.

# ── PostgreSQL (cloud) ───────────────────────────────────────────────────
# Used by both apps/api (NestJS) and apps/engine (Flowise) — same database.
DB_HOST=your-db-host.postgres.database.azure.com
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=flowise
DB_SSL=true

# ── Redis (cloud) ────────────────────────────────────────────────────────
# Not used by any service yet (v0.1+ for BullMQ queues).
# Include now so it's ready when needed.
REDIS_URL=redis://your-redis-host:6379

# ── JWT ──────────────────────────────────────────────────────────────────
# Shared between apps/api (signs tokens) and apps/engine (verifies canvas tokens).
# MUST be identical in both services.
# Generate a strong value:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# ── Email (Brevo SMTP) ────────────────────────────────────────────────────
# If SMTP_PASS is not set, invite URLs are logged to console instead of emailed.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=b050b6001@smtp-brevo.com
SMTP_PASS=your_brevo_smtp_password
SMTP_FROM=noreply@yourdomain.com

# ── App URL ───────────────────────────────────────────────────────────────
# Base URL used to build invite links in emails.
APP_URL=http://localhost:3001
